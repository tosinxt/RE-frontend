rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    // Same as Nest FirebaseAuthGuard: custom claim companyId, else auth uid (per-company doc id).
    function scopeCompanyId() {
      return request.auth.token.keys().hasAll(['companyId']) &&
        request.auth.token.companyId is string &&
        request.auth.token.companyId.size() > 0
        ? request.auth.token.companyId
        : request.auth.uid;
    }

    function isAdmin() {
      return request.auth.token.keys().hasAll(['role']) &&
        request.auth.token.role == 'admin';
    }

    match /companies/{cid} {
      allow read: if signedIn() && scopeCompanyId() == cid;
      allow write: if false; // backend-only

      match /users/{uid} {
        allow read: if signedIn() && scopeCompanyId() == cid;
        allow write: if false; // backend-only (role assignment via admin tooling)
      }

      match /documents/{docId} {
        allow read: if signedIn() && scopeCompanyId() == cid;
        allow write: if false; // backend-only
      }

      match /netsheets/{netsheetId} {
        allow read: if signedIn() && scopeCompanyId() == cid;
        allow write: if false; // backend-only
      }

      match /templates/{templateId} {
        allow read: if signedIn() && scopeCompanyId() == cid;
        allow write: if false; // backend-only
      }

      match /templateVersions/{versionId} {
        allow read: if signedIn() && scopeCompanyId() == cid;
        allow write: if false; // backend-only (publish flow)
      }

      match /audit/{eventId} {
        allow read: if signedIn() && scopeCompanyId() == cid && isAdmin();
        allow write: if false; // backend-only
      }
    }
  }
}
